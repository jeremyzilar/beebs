{{ 'section-nutrition-bar.css' | asset_url | stylesheet_tag }}

<div class="nutrition-bar color-{{ section.settings.color_scheme }} gradient"
  style="--heading-max-width-desktop: {{ section.settings.heading_max_width_desktop }}%; --heading-max-width-mobile: {{ section.settings.heading_max_width_mobile }}%;">
  {%- if section.settings.heading != blank -%}
    <p class="nutrition-bar__heading nutrition-bar__heading--{{ section.settings.heading_weight }}"
       style="font-size: {{ section.settings.heading_size }}rem;">
      {{- section.settings.heading -}}
    </p>
  {%- endif -%}
  {%- if section.settings.deck != blank -%}
    <p class="nutrition-bar__deck">{{- section.settings.deck -}}</p>
  {%- endif -%}
  <div class="nutrition-bar__inner{% if section.settings.full_width == false %} page-width{% endif %}">
    {%- for block in section.blocks -%}
      {%- if block.type == 'stat' -%}
        <div class="nutrition-bar__stat" {{ block.shopify_attributes }}>
          {%- if block.settings.label != blank -%}
            <p class="nutrition-bar__label">{{ block.settings.label }}</p>
          {%- endif -%}
          {%- if block.settings.value != blank -%}
            <p class="nutrition-bar__value">{{ block.settings.value }}</p>
          {%- endif -%}
          {%- if block.settings.sublabel != blank -%}
            <p class="nutrition-bar__sublabel">{{ block.settings.sublabel }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Nutrition bar",
  "tag": "section",
  "class": "section-nutrition-bar",
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "PROTEIN",
          "info": "Short label shown above the value, e.g. HIGH PROTEIN"
        },
        {
          "type": "text",
          "id": "value",
          "label": "Value",
          "default": "82.5%",
          "info": "The large number or stat, e.g. 82.5%"
        },
        {
          "type": "text",
          "id": "sublabel",
          "label": "Sub-label (optional)",
          "info": "Smaller text below the value, e.g. per treat"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading text",
      "info": "Displayed centered above the stats. Leave blank to hide."
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 1.0,
      "max": 6.0,
      "step": 0.1,
      "unit": "rem",
      "default": 2.0
    },
    {
      "type": "textarea",
      "id": "deck",
      "label": "Deck text",
      "info": "Smaller supporting text shown below the heading. Leave blank to hide."
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        { "value": "regular", "label": "Regular" },
        { "value": "bold", "label": "Headline (bold)" }
      ],
      "default": "regular"
    },
    {
      "type": "range",
      "id": "heading_max_width_desktop",
      "label": "Heading max width — desktop",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 65
    },
    {
      "type": "range",
      "id": "heading_max_width_mobile",
      "label": "Heading max width — mobile",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Nutrition bar",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "label": "CALORIES/TREAT",
            "value": "2",
            "sublabel": ""
          }
        },
        {
          "type": "stat",
          "settings": {
            "label": "PROTEIN",
            "value": "82.5%",
            "sublabel": ""
          }
        },
        {
          "type": "stat",
          "settings": {
            "label": "GRASS-FED LAMB",
            "value": "100%",
            "sublabel": ""
          }
        }
      ]
    }
  ]
}
{% endschema %}
