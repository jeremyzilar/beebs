{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer-split.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .footer-split.section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .footer-split.section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<footer
  class="footer-split color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding{% if section.settings.menu_column_side == 'left' %} footer-split--menus-left{% endif %}"
  id="FooterSplit-{{ section.id }}"
  aria-label="{{ shop.name | escape }} — {{ 'sections.footer.name' | t }}"
>
  <div class="footer-split__split">
    <div class="footer-split__col footer-split__col--intro">
      {%- if section.settings.intro_text != blank -%}
        <div class="footer-split__intro rte">{{ section.settings.intro_text }}</div>
      {%- endif -%}

      {%- if section.settings.newsletter_enable -%}
        <div class="footer-split__newsletter-form">
          {%- form 'customer', id: 'ContactFooterSplit--{{ section.id }}', class: 'footer-split__newsletter-form-inner' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="footer-split__newsletter-box">
              <div class="field">
                <input
                  id="NewsletterSplit--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="ContactFooterSplit-error--{{ section.id }}"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="ContactFooterSplit-success--{{ section.id }}"
                  {% endif %}
                  placeholder="{{ 'newsletter.label' | t }}"
                  required
                >
                <label class="field__label visually-hidden" for="NewsletterSplit--{{ section.id }}">
                  {{ 'newsletter.label' | t }}
                </label>
              </div>
              <button
                type="submit"
                class="footer-split__newsletter-submit"
                name="commit"
                aria-label="{{ 'newsletter.button_label' | t }}"
              >
                <span>{{ 'newsletter.button_label' | t }}</span>
                <span class="footer-split__submit-icon" aria-hidden="true">
                  <span class="svg-wrapper">
                    {{- 'icon-arrow.svg' | inline_asset_content -}}
                  </span>
                </span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="ContactFooterSplit-error--{{ section.id }}">
                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="ContactFooterSplit-success--{{ section.id }}"
                tabindex="-1"
                autofocus
              >
                <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>

    <div class="footer-split__col footer-split__col--menus">
      <div class="footer-split__menus">
        {%- for block in section.blocks -%}
          {%- if block.type == 'menu_column' -%}
            <div class="footer-split__menu-col" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="footer-split__menu-heading inline-richtext">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.menu != blank and block.settings.menu.links.size > 0 -%}
                <ul class="footer-split__menu-list">
                  {%- for link in block.settings.menu.links -%}
                    <li>
                      <a href="{{ link.url }}">{{ link.title | escape }}</a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.show_policy_row -%}
        {%- if section.settings.show_policy_links or section.settings.show_copyright -%}
          <div class="footer-split__menus-footer">
            {%- if section.settings.show_policy_links -%}
              <ul class="footer-split__policies" role="list">
                {%- for policy in shop.policies -%}
                  {%- if policy != blank -%}
                    <li>
                      <a href="{{ policy.url }}">{{ policy.title | escape }}</a>
                    </li>
                  {%- endif -%}
                {%- endfor -%}
              </ul>
            {%- endif -%}
            {%- if section.settings.show_copyright -%}
              <p class="footer-split__copyright">
                &copy;
                {%- if section.settings.copyright_uppercase -%}
                  {{ shop.name | upcase }}
                {%- else -%}
                  {{ shop.name }}
                {%- endif %}
                {{ 'now' | date: '%Y' }}
              </p>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- liquid
    assign footer_split_loc = 'FooterSplit' | append: section.id
    assign footer_split_country_lp = footer_split_loc | append: 'Country'
    assign footer_split_language_lp = footer_split_loc | append: 'Language'
  -%}
  {%- if section.settings.show_utility_row -%}
    <div class="footer-split__bottom footer__content-bottom">
      <div class="footer__content-bottom-wrapper page-width">
        <div class="footer__column footer__localization isolate">
          {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
            <localization-form>
              {%- form 'localization', id: 'FooterSplitCountryForm--{{ section.id }}', class: 'localization-form' -%}
                <div>
                  <h2 class="caption-large text-body" id="{{ footer_split_country_lp }}Label">
                    {{ 'localization.country_label' | t }}
                  </h2>
                  {%- render 'country-localization', localPosition: footer_split_country_lp -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}
          {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
            <localization-form>
              {%- form 'localization', id: 'FooterSplitLanguageForm--{{ section.id }}', class: 'localization-form' -%}
                <div>
                  <h2 class="caption-large text-body" id="{{ footer_split_language_lp }}Label">
                    {{ 'localization.language_label' | t }}
                  </h2>
                  {%- render 'language-localization', localPosition: footer_split_language_lp -%}
                </div>
              {%- endform -%}
            </localization-form>
          {%- endif -%}
        </div>
        <div class="footer__column footer__column--info">
          {%- if section.settings.payment_enable -%}
            <div class="footer__payment">
              <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
              <ul class="list list-payment" role="list">
                {%- for type in shop.enabled_payment_types -%}
                  <li class="list-payment__item">
                    {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        </div>
      </div>
      {%- if section.settings.show_powered_by -%}
        <div class="footer__content-bottom-wrapper page-width">
          <div class="footer__copyright caption">
            <small class="copyright__content">{{ powered_by_link }}</small>
          </div>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Split footer",
  "tag": "section",
  "class": "section-footer-split",
  "blocks": [
    {
      "type": "menu_column",
      "name": "Menu column",
      "limit": 3,
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Shop",
          "info": "Reorder columns with drag and drop in the sidebar (top to bottom = left to right on desktop)."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "menu_column_side",
      "label": "Menu columns side",
      "options": [
        { "value": "right", "label": "Right" },
        { "value": "left", "label": "Left" }
      ],
      "default": "right"
    },
    {
      "type": "header",
      "content": "Intro column"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Text",
      "default": "<p>Add a short message above the newsletter form.</p>"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enable",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "header",
      "content": "Menu column footer"
    },
    {
      "type": "checkbox",
      "id": "show_policy_row",
      "label": "Show policy row under menus",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_policy_links",
      "label": "Show policy links (Privacy, Terms, ...)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_copyright",
      "label": "Show copyright on the right",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "copyright_uppercase",
      "label": "Uppercase store name in copyright",
      "default": false
    },
    {
      "type": "header",
      "content": "Optional utility row"
    },
    {
      "type": "checkbox",
      "id": "show_utility_row",
      "label": "Show country / language / payments row",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "label": "t:sections.footer.settings.enable_country_selector.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "label": "t:sections.footer.settings.enable_language_selector.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "payment_enable",
      "label": "t:sections.footer.settings.payment_enable.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_powered_by",
      "label": "Show Powered by Shopify under utilities",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Split footer",
      "blocks": [
        { "type": "menu_column", "settings": { "heading": "Shop" } },
        { "type": "menu_column", "settings": { "heading": "About Us" } },
        { "type": "menu_column", "settings": { "heading": "Social" } }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
