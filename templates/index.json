        "heading_PJYjnn": {
          "type": "heading",
          "settings": {
            "heading": "✨ Get your dog's attention",
            "heading_size": "h2"
          }
        },
        "text_6bnAPd": {
          "type": "text",
          "settings": {
            "text": "<p>Our treats are perfect for training, especially for tough-to-train behaviors like recall, reactiveness, and potty training.</p><h2>✨ Easy for dogs of all sizes and ages</h2><p>Because they are less dense and sticky than other treats, puppies, small dogs, and older dogs can chew and digest them easily.</p><h2>✨ Use as much as you need</h2><p>Our treats are irresistible but also low calorie. Break it up into many small pieces to mark big moments or habituate your pup to the street or the car.</p>",
            "text_style": "body"
          }
        },
        "caption_krBckC": {
          "type": "caption",
          "settings": {
            "caption": "📸 \"Juniper\" — Italian Greyhound, lives in New York City and New Mexico",
            "text_style": "caption-with-letter-spacing",
            "text_size": "medium"
          }
        }
      },
