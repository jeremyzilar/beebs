    "image_with_text_r7gxCg": {
      "type": "image-with-text",
      "blocks": {
        "heading_8ixbwx": {
          "type": "heading",
          "settings": {
            "heading": "✨ Single-ingredient",
            "heading_size": "h2"
          }
        },
        "text_W4NHz4": {
          "type": "text",
          "settings": {
            "text": "<p>100% all natural, gently baked, grass fed lamb lung, with no grains, no gluten, no fillers, nothing but lamb.</p><h2>✨ Low calorie </h2><p>You can reward your dog more often with these high-protein, low fat treats without worrying about their weight.</p><h2>✨ Responsibly sourced</h2><p>Our lamb is sourced from New Zealand, where sheep are grass-fed, humanely raised and free range.</p>",
            "text_style": "body"
          }
        },
        "caption_iHpMbT": {
          "type": "caption",
          "settings": {
            "caption": "📸 \"Tubbs\" — French Bulldog, lives in Florida",
            "text_style": "caption-with-letter-spacing",
